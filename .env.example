# ============================================================
#  PHARMA REGULATORY PULSE — ENVIRONMENT CONFIGURATION
#  Copy this file to .env and fill in your actual API keys.
#  NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# OPENAI (AI Synthesis Engine — two-model split)
# model_writer (gpt-5.4-mini): synthesis, enrichment, QA
# model_worker (gpt-5.4-nano): normalization, dedup scoring, ranking
# Get your key: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=sk-/...
OPENAI_MODEL_WORKER=gpt-5.4-nano

# ------------------------------------------------------------
# RESEND (Email Delivery — Preferred)
# 3,000 emails/month free tier, no credit card required.
# Get your key: https://resend.com/
# ------------------------------------------------------------
RESEND_API_KEY=re_...

# ------------------------------------------------------------
# TAVILY (Primary News Search — Highly Recommended)
# Purpose-built for LLM pipelines. 1,000 free searches/month.
# Get your key: https://tavily.com/
# Without this key the system falls back to RSS + free APIs only.
# ------------------------------------------------------------
TAVILY_API_KEY=tvly-...

# ------------------------------------------------------------
# FDA openFDA API (Optional — increases rate limits)
# Free tier: 1,000 req/day without key | 120,000 with key
# Register: https://open.fda.gov/apis/authentication/
# ------------------------------------------------------------
OPENFDA_API_KEY=odnfA...
OPENFDA_BASE_URL=https://api.fda.gov

# ------------------------------------------------------------
# NIH PubMed / NCBI E-Utilities (Optional — increases rate limits)
# Free: always free with API key (higher rate limits)
# Register: https://www.ncbi.nlm.nih.gov/account/
# ------------------------------------------------------------
PUBMED_API_KEY=...
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# ------------------------------------------------------------
# ClinicalTrials.gov API v2 (No key required)
# Docs: https://clinicaltrials.gov/data-api/api
# ------------------------------------------------------------
CLINICALTRIALS_BASE_URL=https://clinicaltrials.gov/api/v2

# ------------------------------------------------------------
# SMTP Fallback (Alternative to Resend)
# Use if you prefer your own SMTP server.
# Set email.provider = "smtp" in config.yaml to activate.
# ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASSWORD=...
